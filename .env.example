# =============================================================================
# Template only — copy to `.env` at repo root and fill in (`.env` is gitignored).
# Do not commit real secrets here. Add new keys below when you need them; we merge,
# we do not delete your custom lines from your personal `.env`.
#
# Load order:
#   FastAPI/worker: repo `.env` → `backend/.env` → `config/.env`
#   Next.js:        repo `.env` → `config/.env` → `content-machine/.env.local`
#
# Supabase: prefer `SUPABASE_URL` + `SUPABASE_ANON_KEY` (next.config maps to NEXT_PUBLIC_*).
# Optional: set `NEXT_PUBLIC_SUPABASE_*` instead — same values, still supported.
# =============================================================================

# --- Supabase -----------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
# Same key FastAPI uses; required for POST /api/onboarding/complete (Next server-only).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional explicit Next names (legacy / Vercel dashboards — same values as above)
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# --- Next.js ↔ FastAPI --------------------------------------------------------
CONTENT_API_URL=http://127.0.0.1:8787
# On Vercel: set CONTENT_API_URL to your public FastAPI URL (https://api.tudominio.com)
# so /api/cron/daily-sync can call the backend. Browser still uses NEXT_PUBLIC_* if you set it.
# NEXT_PUBLIC_CONTENT_API_URL=http://127.0.0.1:8787
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8787

# --- Worker + scripts (add whatever your pipeline uses — keep them in `.env`) --
APIFY_API_TOKEN=
# Optional: default is apify~instagram-reel-scraper (official Instagram Reel Scraper).
# APIFY_REEL_ACTOR=
# true = request paid share counts (Apify Starter+). Leave false unless shares are product-critical.
# APIFY_INCLUDE_SHARES_COUNT=false
# Own-reel sync hard cap. Daily syncs also use a 30-day actor date filter.
# OWN_REELS_SYNC_RESULTS_LIMIT=100
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview
# Optional: if primary hits HTTP 429, after backoff try this model (text/chat; not image/video).
OPENROUTER_MODEL_FALLBACK=google/gemini-3.1-flash-lite-preview
# Optional: after 429 backoff, retries per model (default 6). See backend/services/openrouter.py.
# OPENROUTER_429_MAX_ATTEMPTS=8
# Cap seconds for one sleep between retries (default 120).
# OPENROUTER_429_MAX_SLEEP_S=180
# Global OpenRouter request pacing across API + worker (default 15/min).
# Requires backend/sql/phase22_openrouter_rate_limit.sql. 0 = disable DB pacer.
# OPENROUTER_REQUESTS_PER_MINUTE=15
# Bounded per-job similarity scoring workers (default 4).
# OPENROUTER_SCORING_WORKERS=4
OPENAI_API_KEY=

# --- FastAPI ------------------------------------------------------------------
# Comma-separated. Add your live site so the browser is allowed to talk to the API.
# Example: CORS_ORIGINS=http://localhost:3000,https://silas-content-system.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Same random string on FastAPI (here) AND on Vercel as CRON_SECRET. Used by:
#   POST /api/v1/cron/sync-all  and  POST /api/v1/cron/recompute-breakouts  (header X-Cron-Secret)
#   and by Next route GET /api/cron/daily-sync (Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=

# --- Optional -----------------------------------------------------------------
# MIGRATE_DEFAULT_ORG_NAME=Agency
